APP_NAME="PopRua CRAS Test"
APP_ENV=testing
APP_KEY=base64:1RZa7D1DFjWn/NOTfg2R91f9eTsRruLI4Gevl6K6wEc=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=error

# DB de testes — mesmo container, banco/usuario dedicados (espelha phpunit.xml)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=poprua_cras_test
DB_USERNAME=poprua_cras_test
DB_PASSWORD=pw

# Sessao em array para nao depender de redis nos testes unitarios
SESSION_DRIVER=array
SESSION_LIFETIME=120

CACHE_STORE=array
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local

# Media conversions sincronas nos testes
MEDIA_QUEUE_CONNECTION=sync

# Redis ainda disponivel se algum teste depender (mesmo container)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array

VITE_APP_NAME="${APP_NAME}"
