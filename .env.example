APP_BRAND="SIZEM"
APP_NAME="SIZEM — Sistema Integrado de Zeladoria Municipal"
APP_HOMOLOGACAO_BANNER=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL com PostGIS
# Em Docker: DB_HOST=pg17-poprua-cras (nome do container, unico globalmente), DB_PORT=5432
# Dev local nativo (PostgreSQL 18.4 + PostGIS 3.6): DB_HOST=127.0.0.1, DB_PORT=5433 (cluster 18/main)
# NAO usar DB_HOST=db — alias service-level pode colidir em redes externas (ver REFERENCIA_DOCKER_LEGADO.md)
DB_CONNECTION=pgsql
DB_HOST=pg17-poprua-cras
DB_PORT=5432
DB_DATABASE=poprua_cras
DB_USERNAME=poprua_cras
DB_PASSWORD=

# MySQL (alternativo - conexão secundária)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=popruav2
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=

# ETL: conexão de origem para migração POPRUA Geo -> CRAS (read-only)
# Container CRAS alcança o Geo via host.docker.internal:5433 (extra_hosts)
ETL_SOURCE_HOST=host.docker.internal
ETL_SOURCE_PORT=5433
ETL_SOURCE_DB=poprua_geo
ETL_SOURCE_USER=poprua_geo
ETL_SOURCE_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Backup off-site (spatie/laravel-backup). BACKUP_DISK=local NAO e off-site.
# Para off-site, apontar p/ um disco s3/sftp e preencher credenciais (ver config/filesystems.php).
BACKUP_DISK=local
BACKUP_NOTIFICATION_EMAIL=admin@example.com
# Opcao S3 (adapter aws-s3-v3): BACKUP_DISK=s3 + AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/AWS_DEFAULT_REGION/AWS_BUCKET (+AWS_ENDPOINT se MinIO/R2)
# Opcao SFTP (adapter sftp-v3): adicionar disco 'sftp' em filesystems + BACKUP_DISK=sftp

CACHE_STORE=redis

# Spatie MediaLibrary — conversions sao enfileiradas na queue default
# (ver Vistoria.php / Morador.php registerMediaConversions com ->queued())

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Em Docker: REDIS_HOST=redis  |  Fora do Docker: REDIS_HOST=127.0.0.1
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage de fotos: Spatie MediaLibrary no disco public local (storage/app/public/).
# Ver ADR-009 — sem Google Drive nem R2.

VITE_APP_NAME="${APP_NAME}"
