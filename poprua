#!/usr/bin/env bash
# ============================================
# poprua — ciclo de dev do PopRua CRAS (git = fonte da verdade)
#
# Hub: GitHub (origin/main). Producao recebe via git pull no deploy.
#
#   LOCAL (dev)                    GITHUB                 PRODUCAO (RMI)
#   clone poprua-cras  --push-->   origin/main  --GA-->   vlcp-sufis01
#
# Push em main dispara deploy automatico via GitHub Actions (self-hosted runner).
# Ver: .github/workflows/deploy-production.yml
#
# Uso:
#   bash poprua st                         # git status LOCAL
#   bash poprua push                       # git push + aguarda deploy automatico
#   bash poprua pull                       # git pull origin main
#   bash poprua deploy                     # deploy manual no servidor (fallback)
#   bash poprua release ["mensagem"]       # commit + push + aguarda deploy
#   bash poprua setup-server               # configura origin no servidor (1x)
#   bash poprua install-auto-deploy        # cron: deploy apos push (poll 3 min)
#   bash poprua art  <args artisan...>     # artisan (precisa RMI)
#   bash poprua logs                       # tail laravel.log (precisa RMI)
#
# Fluxo tipico:
#   git add -A && git commit -m "feat: ..."
#   bash poprua push                         # push dispara deploy no servidor (~30s)
# ============================================
set -uo pipefail

BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORIGIN="${POPRUA_ORIGIN:-git@github.com:murtafilho/poprua-cras.git}"
BRANCH="${POPRUA_BRANCH:-main}"

SSH="ssh -o ConnectTimeout=20 sufis"
DIR=/var/www/html/joomla_sufis/ginfi/poprua-cras
C=php84-poprua-cras
RGIT="sudo git -C $DIR -c safe.directory=*"
LGIT="git -C $BASE"

ensure_origin() {
  if ! $LGIT remote get-url origin &>/dev/null; then
    $LGIT remote add origin "$ORIGIN"
    echo "origin local configurado: $ORIGIN"
  fi
}

watch_deploy() {
  if ! command -v gh &>/dev/null; then
    echo ""
    echo "Push enviado. Deploy automatico dispara no servidor via GitHub Actions."
    echo "Instale 'gh' para acompanhar aqui, ou veja: github.com/murtafilho/poprua-cras/actions"
    return 0
  fi

  echo ""
  echo "Aguardando deploy automatico (Deploy production)..."
  sleep 3

  local run_id
  run_id=$(gh run list --workflow=deploy-production.yml --branch="$BRANCH" --limit=1 --json databaseId --jq '.[0].databaseId' 2>/dev/null) || true
  if [ -z "$run_id" ] || [ "$run_id" = "null" ]; then
    echo "Nao encontrei workflow de deploy — verifique Actions no GitHub."
    return 1
  fi

  if gh run watch "$run_id" --exit-status 2>/dev/null; then
    echo ""
    echo "Deploy em producao concluido."
    return 0
  fi

  echo ""
  echo "Deploy FALHOU. Detalhes: gh run view $run_id --log-failed"
  return 1
}

cmd="${1:-}"; arg="${2:-}"

case "$cmd" in
  st)
    $LGIT status -sb ;;

  push)
    ensure_origin
    $LGIT push -u origin "$BRANCH"
    watch_deploy ;;

  pull)
    ensure_origin
    $LGIT pull --ff-only origin "$BRANCH" ;;

  deploy)
    $SSH "sudo bash $DIR/docker/deploy.sh" ;;

  release)
    if [ -n "$($LGIT status --porcelain --untracked-files=no)" ]; then
      $LGIT add -A
      $LGIT commit -m "${arg:-wip: $(date +%F_%H%M)}"
    fi
    ensure_origin
    $LGIT push -u origin "$BRANCH"
    watch_deploy ;;

  setup-server)
    echo "Configurando origin no servidor ($DIR)..."
    $SSH "sudo git -C $DIR -c safe.directory=* remote remove origin 2>/dev/null || true
      sudo git -C $DIR -c safe.directory=* remote add origin '$ORIGIN'
      sudo git -C $DIR -c safe.directory=* remote -v"
    echo ""
    echo "Testando git fetch origin/$BRANCH no servidor..."
    if $SSH "sudo git -C $DIR -c safe.directory=* fetch origin $BRANCH" 2>&1; then
      echo "OK — servidor alcanca o GitHub. Push em main dispara deploy automatico."
    else
      echo ""
      echo "FALHOU — o servidor precisa de chave SSH de deploy no GitHub."
      echo "No host vlcp-sufis01 (como root):"
      echo "  ssh-keygen -t ed25519 -f /root/.ssh/poprua_cras_deploy -N ''"
      echo "  cat /root/.ssh/poprua_cras_deploy.pub   # adicionar em GitHub > repo > Deploy keys"
      echo "  GIT_SSH_COMMAND='ssh -i /root/.ssh/poprua_cras_deploy -o IdentitiesOnly=yes' git -C $DIR fetch origin"
      exit 1
    fi ;;

  install-auto-deploy)
    $SSH "sudo bash $DIR/docker/install-auto-deploy-cron.sh" ;;

  art)
    shift
    $SSH "sudo docker exec -u www-data $C php $DIR/artisan $*" ;;

  logs)
    $SSH "sudo tail -40 $DIR/storage/logs/laravel.log" ;;

  bootstrap|deploy-bundle|get|put|ship)
    echo "OBSOLETO: use git + GitHub."
    echo "  bash poprua pull          # sincronizar local com GitHub"
    echo "  bash poprua release \"...\"  # commit + push + pull em producao"
    exit 1 ;;

  *)
    sed -n '7,22p' "$0" ;;
esac
